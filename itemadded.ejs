<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <title>Items Added</title>
</head>
<body>
  <main>
    <section class="search-hero">
        <h1>Find what you need on Campus</h1>
       <form action="/search" method="GET" id="filterForm">
    
    <h3>Categories</h3>
    <input type="checkbox" name="category" value="Books"> Books <br>
    <input type="checkbox" name="category" value="Electronics"> Electronics <br>
    <input type="checkbox" name="category" value="Sports Equipment"> Sports Equipment <br>
    
    <h3>Price Range</h3>
    <input type="number" name="minPrice" placeholder="₹ Min">
    <input type="number" name="maxPrice" placeholder="₹ Max">

    <h3>Condition</h3>
    <input type="checkbox" name="condition" value="Brand New"> Brand New <br>
    <input type="checkbox" name="condition" value="Like New"> Like New <br>

    <h3>Sort By</h3>
    <input type="radio" name="sortBy" value="recent" checked> Most Recent <br>
    <input type="radio" name="sortBy" value="priceLowHigh"> Price: Low to High <br>
    <input type="radio" name="sortBy" value="priceHighLow"> Price: High to Low <br>

    <button type="submit" class="btn">Apply Filters</button>
</form>
    </section>

    </main>
    <h2>✅ALL ITEMS TO SELL:</h2>
     <% if (homes.length > 0) { %>
35:         <% homes.forEach(home => { %>
36:             <div style="border:1px solid black; margin:10px; padding:10px;">
37:                 38:             </div>
39:         <% }) %>
40:     <% } else { %>
41:         <p>No items found for this search.</p>
42:     <% } %>
    <% homes.forEach(home => { %>
    <div style="border:1px solid black; margin:10px; padding:10px;">
      <img src="<%=home.photoUrl %>" alt="Product Image" style="width:100%; height:200px; object-fit:contain;">
      <h3>item id:<%=home.id %></h3>
        <h3><%=home.productname %></h3>
        <p>Price: ₹<%=home.price %></p>
        <a class="bg-blue-300 p-2" href="/buyer/<%=home.id%>">Details</a>
    </div>
<% }) %>

    <a href="/add-item">Add More Items</a>
</body>
</html>
